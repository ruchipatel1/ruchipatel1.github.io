# Get an ID from https://formspree.io/ after creating a form (format: https://formspree.io/f/xxxxxxx)
VITE_FORMSPREE_FORM_ID=

# Resume (recommended): latest GitHub Release PDF — updates apply without redeploying this site.
# Uncomment and set OWNER, REPO, and filename to match your release asset.
# VITE_RESUME_PDF_URL=https://github.com/OWNER/REPO/releases/latest/download/resume.pdf

# Optional: LaTeX repo for the “LaTeX source” button on /resume
# VITE_RESUME_SOURCE_REPO_URL=https://github.com/OWNER/REPO

# Optional: hosted preview image (e.g. exported from CI) if you don’t use public/RuchiPatelResume.jpg
# VITE_RESUME_PREVIEW_IMAGE_URL=
